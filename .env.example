LIQUIDLANE_BIND_ADDR=0.0.0.0:8080
LIQUIDLANE_ENV=development
LIQUIDLANE_DATA_PATH=./liquidlane-data.json
# FIBER_RPC_URL=http://127.0.0.1:8227
# FIBER_RPC_AUTH_TOKEN=
LIQUIDLANE_CKB_NETWORK=testnet
LIQUIDLANE_VAULT_ASSET=CKB
LIQUIDLANE_VAULT_SCRIPT_VERSION=v2
LIQUIDLANE_VAULT_CKB_ADDRESS=
LIQUIDLANE_VAULT_CELL_OUT_POINT=
# LIQUIDLANE_VAULT_LOCK_CODE_HASH=0x...
# LIQUIDLANE_VAULT_LOCK_OUT_POINT=0x...#0x0
# LIQUIDLANE_VAULT_TYPE_CODE_HASH=0x...
# LIQUIDLANE_VAULT_TYPE_OUT_POINT=0x...#0x1
# LIQUIDLANE_LP_RECEIPT_TYPE_CODE_HASH=0x...
# LIQUIDLANE_LP_RECEIPT_TYPE_OUT_POINT=0x...#0x2
# LIQUIDLANE_REQUEST_TYPE_CODE_HASH=0x...
# LIQUIDLANE_REQUEST_TYPE_OUT_POINT=0x...#0x3
# LIQUIDLANE_FUNDING_INTENT_TYPE_CODE_HASH=0x...
# LIQUIDLANE_FUNDING_INTENT_TYPE_OUT_POINT=0x...#0x4
# LIQUIDLANE_FEE_CLAIM_TYPE_CODE_HASH=0x...
# LIQUIDLANE_FEE_CLAIM_TYPE_OUT_POINT=0x...#0x5

# CKB RPC verification for real settlements
LIQUIDLANE_CKB_RPC_URL=
LIQUIDLANE_REQUIRE_CKB_RPC=false
LIQUIDLANE_CKB_ACCEPT_PENDING_TXS=true
LIQUIDLANE_CKB_SCRIPT_BUILD_DIR=./ckb-scripts/build

# Vault-funded Fiber execution
LIQUIDLANE_FIBER_FUNDING_MODE=vault_external
LIQUIDLANE_EXECUTOR_ENABLED=true
LIQUIDLANE_EXECUTOR_CKB_ADDRESS=
LIQUIDLANE_VAULT_FUNDING_BUILDER_ENABLED=true
LIQUIDLANE_VAULT_FUNDING_SIGNER_ENABLED=true
# Set this on the Fiber node service, pointing at Core:
# LIQUIDLANE_CORE_FUNDING_BUILDER_URL=https://<core-host>/internal/fiber/funding-builder
